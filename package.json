{
  "name": "onward2",
  "version": "2.0.1",
  "productName": "Onward 2",
  "author": "OPPO",
  "description": "VS Code style terminal application built with Electron + React",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OPPO-PersonalAI/Onward-Agent-Workbench.git"
  },
  "onward": {
    "updateManifestBaseUrl": "https://raw.githubusercontent.com/OPPO-PersonalAI/Onward/gh-pages/updates"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "prepare": "husky",
    "predev": "pnpm typecheck",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3 && node scripts/ensure-ripgrep-binary.js",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "lint:comments": "node scripts/check-chinese-comments.js",
    "compile:changelog": "node scripts/compile-changelog.js",
    "generate:changelog": "node scripts/generate-changelog.js",
    "generate:icons": "node scripts/generate-icons.js",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:dev": "node scripts/dist-dev.js",
    "dist:release": "node scripts/dist-release.js",
    "generate-notices": "license-checker-rseidelsohn --production --plainVertical --out ThirdPartyNotices.txt",
    "verify:seti-file-tree": "node test/autotest/seti-file-tree-icon-verify.mjs"
  },
  "build": {
    "appId": "com.onward2.app",
    "productName": "Onward 2",
    "copyright": "Copyright © 2026 OPPO",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "node_modules/@vscode/ripgrep/**"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      },
      {
        "from": "NOTICE.txt",
        "to": "."
      },
      {
        "from": "ThirdPartyNotices.txt",
        "to": "."
      },
      {
        "from": "LICENSE",
        "to": "."
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "icon": "resources/icons",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@pierre/diffs": "^1.0.10",
    "@vscode/ripgrep": "^1.15.11",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "applicationinsights": "^3.14.0",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.2",
    "epubjs": "^0.3.93",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "marked": "^17.0.1",
    "marked-katex-extension": "^5.1.7",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "panzoom": "^9.4.4",
    "seti-icons": "0.0.4"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "5.0.1",
      "@xmldom/xmldom": "0.8.12",
      "ajv": "6.14.0",
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@2.0.2": "2.0.3",
      "dompurify": "3.3.3",
      "lodash": "4.18.1",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@5.1.6": "5.1.8",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@10.1.1": "10.2.5",
      "picomatch": "4.0.4",
      "rollup": "4.60.1",
      "tar": ">=7.5.8",
      "https-proxy-agent": ">=7.0.6"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "39.8.5",
    "electron-builder": "^26.8.0",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^4.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.0",
    "vite": "^6.4.2"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
